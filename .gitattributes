# Normalize line endings across platforms.
# Without this, Windows would check out CRLF copies of shell scripts,
# which then fail on the Linux droplet with "/bin/bash^M: bad interpreter".

# Default: let git auto-detect text vs binary, normalize text to LF in the repo.
* text=auto eol=lf

# Hard lock these file types to LF — they run on Linux only.
*.sh         text eol=lf
*.yml        text eol=lf
*.yaml       text eol=lf
Dockerfile   text eol=lf
Caddyfile    text eol=lf
.env*        text eol=lf

# Windows-native files should stay CRLF.
*.ps1        text eol=crlf
*.bat        text eol=crlf
*.cmd        text eol=crlf

# Binaries — never touch.
*.png        binary
*.jpg        binary
*.pdf        binary
*.zip        binary
*.tgz        binary
*.gz         binary
