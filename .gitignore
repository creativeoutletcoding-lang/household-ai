# secrets — never commit
.env
*.env.local
*.key
*.pem
secrets/

# generated at install time — environment-specific, must not be committed
docker-compose.override.yml

# local state that docker bind-mounts write to
/data/
/backups/

# caddy runtime (generated by install.sh, contains certs + keys)
/caddy/data/
/caddy/config/

# editor junk
.DS_Store
.vscode/
.idea/
*.swp

scripts/node_modules/
scripts/package-lock.json
