# Household AI — environment template
# ---------------------------------------------------------------------------
# Copy to .env and fill in every value. `.env` is gitignored.
# Generate long random secrets with:   openssl rand -hex 32
# ---------------------------------------------------------------------------

# --- Domain --------------------------------------------------------------
# The root domain. Caddy will auto-provision certificates for:
#   ${DOMAIN}, chat.${DOMAIN}, n8n.${DOMAIN}
DOMAIN=creativeoutletcoding.com

# Contact email used by Let's Encrypt for cert expiry warnings.
ACME_EMAIL=you@example.com

# IANA timezone, used by n8n cron triggers and Watchtower.
TZ=America/Los_Angeles

# --- Anthropic (Claude) --------------------------------------------------
# Create at https://console.anthropic.com/ — starts with `sk-ant-...`
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# Default model the household uses. Override per workflow if needed.
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Telegram bot --------------------------------------------------------
# Create a bot with @BotFather on Telegram, paste the HTTP API token here.
# The n8n Telegram trigger node reads this at runtime.
TELEGRAM_BOT_TOKEN=REPLACE_ME

# Comma-separated list of Telegram user IDs allowed to talk to the bot.
# Find your ID by messaging @userinfobot. This is enforced inside the n8n
# workflow; anyone outside the list gets a canned "not authorized" reply.
TELEGRAM_ALLOWED_USER_IDS=

# --- Postgres ------------------------------------------------------------
# Single superuser, three databases (one per service). Not exposed to host.
POSTGRES_USER=household
POSTGRES_PASSWORD=REPLACE_WITH_LONG_RANDOM_STRING
POSTGRES_DB=household            # bootstrap/admin db
N8N_DB=n8n
OPENWEBUI_DB=openwebui

# --- n8n -----------------------------------------------------------------
# Basic-auth wrapper on the editor. You still need a separate n8n login
# once that is set up inside the app.
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=REPLACE_WITH_LONG_RANDOM_STRING

# Used to encrypt stored credentials (e.g. the Telegram token, Claude key).
# DO NOT change this after first run or existing credentials become unreadable.
# Generate with: openssl rand -hex 32
N8N_ENCRYPTION_KEY=REPLACE_WITH_OPENSSL_RAND_HEX_32

# --- Open WebUI ----------------------------------------------------------
# Signed cookie / session secret. Generate with: openssl rand -hex 32
OPENWEBUI_SECRET_KEY=REPLACE_WITH_OPENSSL_RAND_HEX_32

# Keep signups OFF after you create the 4 family accounts.
# Flip to "true" only while onboarding; flip back when done.
OPENWEBUI_ENABLE_SIGNUP=false

# Role assigned to new signups when ENABLE_SIGNUP=true. "pending" means the
# admin has to approve them before they can chat.
OPENWEBUI_DEFAULT_ROLE=pending
