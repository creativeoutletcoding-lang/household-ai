# Household AI — environment template
# ---------------------------------------------------------------------------
# Copy to .env and fill in every value. `.env` is gitignored.
# Generate long random secrets with:   openssl rand -hex 32
# ---------------------------------------------------------------------------

# --- Domain --------------------------------------------------------------
# The root domain. Caddy will auto-provision certificates for:
#   ${DOMAIN}, chat.${DOMAIN}, n8n.${DOMAIN}
DOMAIN=creativeoutletcoding.com

# Contact email used by Let's Encrypt for cert expiry warnings.
ACME_EMAIL=you@example.com

# IANA timezone, used by n8n cron triggers and Watchtower.
TZ=America/Los_Angeles

# --- Anthropic (Claude) --------------------------------------------------
# Create at https://console.anthropic.com/ — starts with `sk-ant-...`
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# Default model the household uses. Override per workflow if needed.
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Replicate (image generation via /image) -----------------------------
# Create a token at https://replicate.com/account/api-tokens. Bruce uses
# black-forest-labs/flux-schnell for `/image <prompt>` and flux-pro for
# `/image --hd <prompt>`.
REPLICATE_API_TOKEN=REPLACE_ME

# --- Perplexity (web search via /search) ---------------------------------
# Create a key at https://www.perplexity.ai/settings/api. Bruce uses the
# `sonar` model for `/search <query>` — returns an answer plus citations.
PERPLEXITY_API_KEY=REPLACE_ME

# --- Telegram bot --------------------------------------------------------
# Create a bot with @BotFather on Telegram, paste the HTTP API token here.
# The n8n Telegram trigger node reads this at runtime.
TELEGRAM_BOT_TOKEN=REPLACE_ME

# Comma-separated list of Telegram user IDs allowed to talk to the bot.
# Find your ID by messaging @userinfobot. This is enforced inside the n8n
# workflow; anyone outside the list gets a canned "not authorized" reply.
TELEGRAM_ALLOWED_USER_IDS=

# --- Discord bot ---------------------------------------------------------
# Create an application at https://discord.com/developers/applications,
# add a bot, copy the token. Full walkthrough: docs/discord-setup.md.
#
# Used by:
#   - discord-relay (Gateway connection)
#   - n8n (direct Discord REST API calls for image sending)
DISCORD_BOT_TOKEN=REPLACE_ME

# The guild (server) ID — right-click server in Discord with Developer Mode
# on and "Copy Server ID".
DISCORD_SERVER_ID=REPLACE_ME

# The bot's OWN user ID — same as the Application ID in the Developer Portal,
# or right-click Bruce in your server's member list and Copy User ID. The
# n8n workflow uses this to detect @mentions and replies to the bot.
DISCORD_BOT_USER_ID=REPLACE_ME

# Family member Discord user IDs (optional — leave blank until they join).
# The provisioner grants each of them explicit access to the categories
# they should see. Find by right-clicking their name -> Copy User ID.
DISCORD_JAKE_USER_ID=
DISCORD_LOUBI_USER_ID=
DISCORD_JOCE_USER_ID=
DISCORD_NANA_USER_ID=

# --- Discord relay ------------------------------------------------------
# The discord-relay container holds the Discord Gateway connection and POSTs
# every incoming message to this n8n webhook URL. Default is the internal
# compose DNS name; only change it if you want the relay to target something
# other than the local n8n (e.g. an external test instance).
N8N_WEBHOOK_URL=http://n8n:5678/webhook/discord-bruce

# --- Postgres ------------------------------------------------------------
# Single superuser, three databases (one per service). Not exposed to host.
POSTGRES_USER=household
POSTGRES_PASSWORD=REPLACE_WITH_LONG_RANDOM_STRING
POSTGRES_DB=household            # bootstrap/admin db
N8N_DB=n8n
OPENWEBUI_DB=openwebui

# --- n8n -----------------------------------------------------------------
# Pinned n8n version. Look up the latest stable 1.x tag at:
#   https://hub.docker.com/r/n8nio/n8n/tags
# Do NOT use `latest` — the `dbTime.getTime` bug has silently shipped in
# some recent builds. Bump this value intentionally (and re-run scripts/
# smoke-test.sh after) rather than letting :latest drift.
N8N_VERSION=1.84.3

# Basic-auth wrapper on the editor. You still need a separate n8n login
# once that is set up inside the app.
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=REPLACE_WITH_LONG_RANDOM_STRING

# n8n REST API key — generate in the n8n UI under Settings → n8n API →
# "Create an API key". Required by scripts/import-workflow.js and
# scripts/sync-workflow.sh because the /api/v1/* endpoints do NOT accept
# the basic-auth credentials above (those only gate the editor UI).
N8N_API_KEY=

# Used to encrypt stored credentials (e.g. the Telegram token, Claude key).
# DO NOT change this after first run or existing credentials become unreadable.
# Generate with: openssl rand -hex 32
N8N_ENCRYPTION_KEY=REPLACE_WITH_OPENSSL_RAND_HEX_32

# --- Open WebUI ----------------------------------------------------------
# Signed cookie / session secret. Generate with: openssl rand -hex 32
OPENWEBUI_SECRET_KEY=REPLACE_WITH_OPENSSL_RAND_HEX_32

# Keep signups OFF after you create the 4 family accounts.
# Flip to "true" only while onboarding; flip back when done.
OPENWEBUI_ENABLE_SIGNUP=false

# Role assigned to new signups when ENABLE_SIGNUP=true. "pending" means the
# admin has to approve them before they can chat.
OPENWEBUI_DEFAULT_ROLE=pending
